{% macro continueBtn(postUrl, label, icon='fa-arrow-right') %}
<p>
  <a href="{{ postUrl }}" class="button">
    <span class="icon is-small">
      <i class="fas {{ icon }}"></i>
    </span>
    <span>{{ label }}</span>
  </a>
</p>
{% endmacro %}

{% macro timestampLink(dt, linkUrl) %}
<time
  datetime="{{ dt.toUTCString() }}"
  class="subtitle is-6 mt-4 mb-0">
  <a href="{{ linkUrl }}">
    {{ dt | displayDate }}
  </a>
</time>
{% endmacro %}

{%- set url = post.url or "/{{ post.data.postType }}" %}

<article class="card {{ post.data.postType }}" data-url="{{ post.url }}">
  <div class="card-content">
    <div class="content">
      {{ timestampLink(post.date, url) }}
      <h1>{{ post.data.title }}</h1>
      {%- if post.data.postType === "terminal-themes" %}
        {% set colors = post.data.colors %}
        {% set bg = post.data.bg %}
        {% include "includes/themeColors.njk" %}
      {%- else %}
        <div class="excerpt">{{ post.templateContent | safe }}</div>
      {%- endif %}

      {%- if post.data.continueButton %}
        {{ continueBtn(url, post.data.continueButton.label, post.data.continueButton.icon) }}
      {%- endif %}
    </div>
  </div>
</article>