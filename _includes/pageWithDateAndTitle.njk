{% extends "base.njk" %}

{%- block contentTitle %}
  <header>
    <h2 class="is-subtitle">
      <time
        datetime="{{ date.toUTCString() }}"
        class="subtitle is-6 mt-4 mb-0">
        <a href="{{ url }}">
          {{ date | displayDate }}
        </a>
      </time>
    </h2>
    <h1 class="title is-2">{{ title }}</h1>
  </header>
{%- endblock %}

{%- block content %}
  <div class="section px-0">
    <div class="content">
      {{ content | safe }}
    </div>
  </div>
{%- endblock content %}
