---
eleventyExcludeFromCollections: true
---

{% extends "base.njk" %}

{%- block contentTitle %}
  <h1 class="title is-2">
    Presentations
  </h1>
{%- endblock contentTitle %}

{%- block content %}
  <div class="content">
    <ul>
        {%- for presentation in presentations.posts %}
        
        <li id="{{ presentation.title | slug }}" class="subtitle is-4"><a href="{{ presentation.permalink }}">{{ presentation.title }}</a></li>
        {%- endfor %}
    </ul>
  </div>
{%- endblock content %}